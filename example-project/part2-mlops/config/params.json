{
    "project_name": "churn-example",
    "region": "eu-west-1",
    "role_arn": "arn:aws:iam::YOUR_ACCOUNT_ID:role/YOUR_SAGEMAKER_ROLE",
    "pipeline_name": "churn-prediction-pipeline",
    "model_package_group_name": "churn-models",

    "processing_instance_type": "ml.m5.xlarge",
    "training_instance_type": "ml.m5.xlarge",
    "inference_instance_type": "ml.m5.large",

    "hyperparameters": {
        "objective": "binary:logistic",
        "num_round": "100",
        "max_depth": "5",
        "eta": "0.2",
        "subsample": "0.8",
        "colsample_bytree": "0.8",
        "eval_metric": "auc"
    },

    "quality_gate": {
        "min_auc": 0.75,
        "min_precision": 0.65,
        "min_recall": 0.60
    }
}
